def main():
    print("🐟 Manjubinha Analises — Iniciando")
    print(f"   Data: {datetime.today().strftime('%Y-%m-%d %H:%M')}")
    
    config   = carregar_config()
    controle = carregar_controle()
    
    # Retroativo: busca documentos desde início de junho/2026
    # Após a primeira rodada, muda para últimos 7 dias automaticamente
    if not controle:
        print("   📅 Primeira execução: buscando documentos desde 01/06/2026")
        desde_data = datetime(2026, 6, 1)
    else:
        print("   📅 Buscando documentos dos últimos 8 dias")
        desde_data = datetime.today() - timedelta(days=8)
    
    processar_fiis(config, controle, desde_data)
    processar_acoes(config, controle, desde_data)
    
    print("\n✅ Concluído!")

if __name__ == "__main__":
    main()
